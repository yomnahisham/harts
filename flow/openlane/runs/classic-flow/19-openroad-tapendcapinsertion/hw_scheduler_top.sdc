set_input_transition -max 0.9200 [get_ports {ext_irq[1]}]
set_input_transition -min 0.0700 [get_ports {ext_irq[0]}]
set_input_transition -max 0.9200 [get_ports {ext_irq[0]}]
set_case_analysis 0 [get_ports {scan_en}]
###############################################################################
# Design Rules
###############################################################################
set_max_transition 0.7500 [current_design]
set_max_fanout 24.0000 [current_design]
